<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HydroLead | Professional Document Generator</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif:wght@400;700&family=Inter:wght@400;700;900&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f3f4f6; }
        .font-serif { font-family: 'Noto Serif', 'Times New Roman', serif; }
        
        #doc-canvas {
            min-height: 1056px;
            width: 100%;
            max-width: 850px;
            background: white;
            padding: 60px 80px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
        }

        @media print {
            .no-print { display: none !important; }
            body { background: white !important; padding: 0 !important; margin: 0 !important; }
            .print-container { padding: 0 !important; margin: 0 !important; width: 100% !important; }
            #doc-canvas { 
                max-width: 100% !important; 
                box-shadow: none !important; 
                padding: 0.5in !important; 
                margin: 0 !important;
                border: none !important;
            }
            @page { margin: 0; }
        }

        input, select, textarea {
            transition: all 0.2s;
            border: 1px solid #e5e7eb;
        }
        input:focus, select:focus, textarea:focus {
            outline: none;
            border-color: #2563eb;
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
        }

        .tab-active {
            background-color: #111827;
            color: white;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        }

        .switch {
            position: relative;
            display: inline-block;
            width: 44px;
            height: 24px;
        }
        .switch input { opacity: 0; width: 0; height: 0; }
        .slider {
            position: absolute;
            cursor: pointer;
            top: 0; left: 0; right: 0; bottom: 0;
            background-color: #d1d5db;
            transition: .4s;
            border-radius: 24px;
        }
        .slider:before {
            position: absolute;
            content: "";
            height: 18px; width: 18px;
            left: 3px; bottom: 3px;
            background-color: white;
            transition: .4s;
            border-radius: 50%;
        }
        input:checked + .slider { background-color: #2563eb; }
        input:checked + .slider:before { transform: translateX(20px); }
    </style>
</head>
<body>

    <div class="flex flex-col lg:flex-row min-h-screen">
        <!-- SIDEBAR - CONTROLS -->
        <div class="w-full lg:w-96 bg-white border-r border-gray-200 p-6 overflow-y-auto no-print h-screen sticky top-0">
            <div class="flex items-center gap-3 mb-8">
                <div class="bg-gray-900 p-2.5 rounded-lg text-white">
                    <i data-lucide="building-2"></i>
                </div>
                <div>
                    <h1 class="font-black text-xl tracking-tighter text-gray-900 uppercase leading-none">HYDROLEAD</h1>
                    <p class="text-[10px] uppercase font-bold text-gray-400 tracking-[0.4em] mt-1">Legal Portfolio</p>
                </div>
            </div>

            <nav class="flex flex-col gap-2 mb-8">
                <button onclick="setActiveTab('purchase')" id="btn-purchase" class="tab-active flex items-center gap-3 px-4 py-3.5 rounded-xl text-sm font-bold transition-all">
                    <i data-lucide="file-text" class="w-4 h-4"></i> Purchase Agreement
                </button>
                <button onclick="setActiveTab('assignment')" id="btn-assignment" class="flex items-center gap-3 px-4 py-3.5 rounded-xl text-sm font-bold text-gray-500 hover:bg-gray-50 transition-all">
                    <i data-lucide="plus" class="w-4 h-4"></i> Assignment Contract
                </button>
                <button onclick="setActiveTab('occupancy')" id="btn-occupancy" class="flex items-center gap-3 px-4 py-3.5 rounded-xl text-sm font-bold text-gray-500 hover:bg-gray-50 transition-all">
                    <i data-lucide="clock" class="w-4 h-4"></i> Occupancy Addendum
                </button>
            </nav>

            <div class="space-y-6">
                <!-- PARTIES -->
                <div class="pt-2">
                    <div class="flex items-center gap-2 mb-4 border-b pb-2">
                        <i data-lucide="users" class="w-4 h-4 text-blue-600"></i>
                        <h3 class="text-xs font-black uppercase tracking-widest text-gray-400">Section 1: Parties</h3>
                    </div>
                    <div class="space-y-4">
                        <div class="flex flex-col gap-1.5">
                            <label class="text-[10px] font-black text-gray-400 uppercase tracking-wider">Effective Date</label>
                            <input type="text" id="effectiveDate" class="w-full px-4 py-2.5 rounded-lg text-sm bg-gray-50 border-gray-200" oninput="updateVal('effectiveDate', this.value)">
                        </div>
                        <div class="flex flex-col gap-1.5">
                            <label class="text-[10px] font-black text-gray-400 uppercase tracking-wider">Seller Legal Name(s)</label>
                            <input type="text" id="sellerName" placeholder="Full Legal Name" class="w-full px-4 py-2.5 rounded-lg text-sm border-gray-200" oninput="updateVal('sellerName', this.value)">
                        </div>
                        <div class="flex flex-col gap-1.5">
                            <label class="text-[10px] font-black text-gray-400 uppercase tracking-wider">Seller Mailing Address</label>
                            <input type="text" id="sellerMailingAddress" placeholder="Street, City, State, ZIP" class="w-full px-4 py-2.5 rounded-lg text-sm border-gray-200" oninput="updateVal('sellerMailingAddress', this.value)">
                        </div>
                    </div>
                </div>

                <!-- PROPERTY -->
                <div class="pt-4">
                    <div class="flex items-center gap-2 mb-4 border-b pb-2">
                        <i data-lucide="map-pin" class="w-4 h-4 text-blue-600"></i>
                        <h3 class="text-xs font-black uppercase tracking-widest text-gray-400">Section 2: Property</h3>
                    </div>
                    <div class="space-y-4">
                        <input type="text" id="propertyAddress" placeholder="Property Street Address" class="w-full px-4 py-2.5 rounded-lg text-sm" oninput="updateVal('propertyAddress', this.value)">
                        <div class="grid grid-cols-2 gap-3">
                            <input type="text" id="propertyCity" placeholder="City" class="w-full px-4 py-2.5 rounded-lg text-sm" oninput="updateVal('propertyCity', this.value)">
                            <input type="text" id="propertyState" placeholder="State (e.g. TX)" class="w-full px-4 py-2.5 rounded-lg text-sm uppercase" oninput="updateVal('propertyState', this.value)">
                        </div>
                        <input type="text" id="propertyCounty" placeholder="County" class="w-full px-4 py-2.5 rounded-lg text-sm" oninput="updateVal('propertyCounty', this.value)">
                        <textarea id="legalDescription" placeholder="Legal Description (Lot, Block, Subdivision)" class="w-full px-4 py-2.5 rounded-lg text-sm h-20" oninput="updateVal('legalDescription', this.value)"></textarea>
                    </div>
                </div>

                <!-- DYNAMIC CONFIG -->
                <div id="dynamic-sidebar" class="pt-4">
                    <!-- Loaded via JS -->
                </div>

                <div class="pt-6 border-t pb-20">
                    <button onclick="window.print()" class="w-full flex items-center justify-center gap-3 bg-blue-600 text-white py-5 rounded-2xl font-black text-sm tracking-widest hover:bg-blue-700 transition-all shadow-xl hover:shadow-blue-200 active:scale-95 uppercase">
                        <i data-lucide="printer" class="w-5 h-5"></i> Generate Legal PDF
                    </button>
                    <p class="text-[10px] text-gray-400 text-center mt-4 uppercase font-bold tracking-tighter">HydroLead Internal Tool v4.2</p>
                </div>
            </div>
        </div>

        <!-- PREVIEW AREA -->
        <div class="flex-1 p-12 overflow-y-auto flex justify-center print-container bg-slate-200">
            <div id="doc-canvas" class="font-serif text-gray-900 border border-gray-300">
                <!-- Content injected via update() -->
            </div>
        </div>
    </div>

    <script>
        let activeTab = 'purchase';
        const data = {
            effectiveDate: new Date().toLocaleDateString(),
            sellerName: '',
            sellerMailingAddress: '',
            buyerName: 'HydroLead Capital Ventures LLC and/or assigns',
            buyerMailingAddress: 'PO BOX 1641 Martinsburg, WV 25402',
            propertyAddress: '',
            propertyCity: '',
            propertyState: 'TX',
            propertyZip: '',
            propertyCounty: '',
            legalDescription: '',
            
            // Purchase Defaults
            purchasePrice: '',
            earnestMoney: '10.00',
            emdDeadlineDays: '3',
            inspectionDays: '14',
            closingDate: '',
            titleCompany: 'To be selected by Buyer',
            titlePolicyPayor: 'Seller',

            // Assignment Defaults
            assigneeName: '',
            assigneeAddress: '',
            assignmentFee: '',
            originalContractDate: '',
            assignmentEMD: '5,000.00',
            assignmentEMDDeadline: '24',

            // Occupancy Defaults
            moveOutDate: '',
            moveOutTime: '5:00 PM',
            holdbackEnabled: true,
            holdbackAmount: '2500.00',
            dailyPenaltyEnabled: true,
            dailyRate: '150.00',
            rentEnabled: false,
            rentAmount: '0.00',
            alterationProtection: true,
            utilityOption: 'seller'
        };

        function setActiveTab(tab) {
            activeTab = tab;
            document.querySelectorAll('nav button').forEach(btn => {
                btn.classList.remove('tab-active', 'text-white');
                btn.classList.add('text-gray-500', 'hover:bg-gray-50');
            });
            const activeBtn = document.getElementById(`btn-${tab}`);
            activeBtn.classList.add('tab-active');
            activeBtn.classList.remove('text-gray-500', 'hover:bg-gray-50');
            renderSidebar();
            update();
        }

        function toggle(name) {
            data[name] = !data[name];
            renderSidebar();
            update();
        }

        function renderSidebar() {
            const container = document.getElementById('dynamic-sidebar');
            if (activeTab === 'purchase') {
                container.innerHTML = `
                    <div class="flex items-center gap-2 mb-4 border-b pb-2">
                        <i data-lucide="dollar-sign" class="w-4 h-4 text-blue-600"></i>
                        <h3 class="text-xs font-black uppercase tracking-widest text-gray-400">Section 3: Financials</h3>
                    </div>
                    <div class="space-y-4">
                        <div class="flex flex-col gap-1.5"><label class="text-[10px] font-black text-gray-400 uppercase">Purchase Price</label><input type="text" placeholder="e.g. 340,000" class="w-full px-4 py-2.5 rounded-lg text-sm" value="${data.purchasePrice}" oninput="updateVal('purchasePrice', this.value)"></div>
                        <div class="flex flex-col gap-1.5"><label class="text-[10px] font-black text-gray-400 uppercase">Earnest Money (EMD)</label><input type="text" placeholder="10.00" class="w-full px-4 py-2.5 rounded-lg text-sm" value="${data.earnestMoney}" oninput="updateVal('earnestMoney', this.value)"></div>
                        <div class="flex flex-col gap-1.5"><label class="text-[10px] font-black text-gray-400 uppercase">Inspection Period (Days)</label><input type="text" placeholder="14" class="w-full px-4 py-2.5 rounded-lg text-sm" value="${data.inspectionDays}" oninput="updateVal('inspectionDays', this.value)"></div>
                        <div class="flex flex-col gap-1.5"><label class="text-[10px] font-black text-gray-400 uppercase">Closing Date</label><input type="date" class="w-full px-4 py-2.5 rounded-lg text-sm" value="${data.closingDate}" oninput="updateVal('closingDate', this.value)"></div>
                        <select class="w-full px-4 py-2.5 rounded-lg text-sm font-bold bg-gray-50" onchange="updateVal('titlePolicyPayor', this.value)">
                            <option value="Seller" ${data.titlePolicyPayor === 'Seller' ? 'selected' : ''}>Seller Pays Title Policy</option>
                            <option value="Buyer" ${data.titlePolicyPayor === 'Buyer' ? 'selected' : ''}>Buyer Pays Title Policy</option>
                        </select>
                    </div>
                `;
            } else if (activeTab === 'assignment') {
                container.innerHTML = `
                    <div class="flex items-center gap-2 mb-4 border-b pb-2">
                        <i data-lucide="shield-check" class="w-4 h-4 text-blue-600"></i>
                        <h3 class="text-xs font-black uppercase tracking-widest text-gray-400">Assignment Terms</h3>
                    </div>
                    <div class="space-y-4">
                        <input type="text" placeholder="Assignee (End Buyer) Name" class="w-full px-4 py-2.5 rounded-lg text-sm" value="${data.assigneeName}" oninput="updateVal('assigneeName', this.value)">
                        <input type="text" placeholder="Assignee Mailing Address" class="w-full px-4 py-2.5 rounded-lg text-sm" value="${data.assigneeAddress}" oninput="updateVal('assigneeAddress', this.value)">
                        <div class="flex flex-col gap-1.5"><label class="text-[10px] font-black text-gray-400 uppercase">Assignment Fee ($)</label><input type="text" placeholder="Assignment Fee Amount" class="w-full px-4 py-2.5 rounded-lg text-sm" value="${data.assignmentFee}" oninput="updateVal('assignmentFee', this.value)"></div>
                        <div class="flex flex-col gap-1.5"><label class="text-[10px] font-black text-gray-400 uppercase">Assignee EMD ($)</label><input type="text" placeholder="5,000.00" class="w-full px-4 py-2.5 rounded-lg text-sm" value="${data.assignmentEMD}" oninput="updateVal('assignmentEMD', this.value)"></div>
                        <div class="grid grid-cols-2 gap-3">
                            <div class="flex flex-col gap-1.5"><label class="text-[10px] font-black text-gray-400 uppercase">EMD Due (Hrs)</label><input type="text" placeholder="24" class="w-full px-4 py-2.5 rounded-lg text-sm" value="${data.assignmentEMDDeadline}" oninput="updateVal('assignmentEMDDeadline', this.value)"></div>
                            <div class="flex flex-col gap-1.5"><label class="text-[10px] font-black text-gray-400 uppercase">Orig. Contract Date</label><input type="date" class="w-full px-4 py-2.5 rounded-lg text-sm" value="${data.originalContractDate}" oninput="updateVal('originalContractDate', this.value)"></div>
                        </div>
                    </div>
                `;
            } else {
                container.innerHTML = `
                    <div class="flex items-center gap-2 mb-4 border-b pb-2">
                        <i data-lucide="settings-2" class="w-4 h-4 text-blue-600"></i>
                        <h3 class="text-xs font-black uppercase tracking-widest text-gray-400">Configurable Addendum</h3>
                    </div>
                    <div class="space-y-2 bg-gray-50 p-4 rounded-xl border border-gray-100">
                        <div class="flex justify-between items-center"><span class="text-xs font-bold text-gray-700">Escrow Holdback</span><label class="switch"><input type="checkbox" onchange="toggle('holdbackEnabled')" ${data.holdbackEnabled ? 'checked' : ''}><span class="slider"></span></label></div>
                        <div class="flex justify-between items-center"><span class="text-xs font-bold text-gray-700">Daily Penalty</span><label class="switch"><input type="checkbox" onchange="toggle('dailyPenaltyEnabled')" ${data.dailyPenaltyEnabled ? 'checked' : ''}><span class="slider"></span></label></div>
                        <div class="flex justify-between items-center"><span class="text-xs font-bold text-gray-700">Charge Rent</span><label class="switch"><input type="checkbox" onchange="toggle('rentEnabled')" ${data.rentEnabled ? 'checked' : ''}><span class="slider"></span></label></div>
                        <div class="flex justify-between items-center border-t mt-2 pt-2"><span class="text-xs font-bold text-gray-700">Alteration Lock</span><label class="switch"><input type="checkbox" onchange="toggle('alterationProtection')" ${data.alterationProtection ? 'checked' : ''}><span class="slider"></span></label></div>
                    </div>
                    <div class="space-y-4 mt-4">
                        <div class="flex flex-col gap-1.5"><label class="text-[10px] font-black text-gray-400 uppercase">Move-Out Date</label><input type="date" class="w-full px-4 py-2.5 rounded-lg text-sm" value="${data.moveOutDate}" oninput="updateVal('moveOutDate', this.value)"></div>
                        ${data.holdbackEnabled ? `<input type="text" placeholder="Holdback Amount ($)" class="w-full px-4 py-2.5 rounded-lg text-sm" value="${data.holdbackAmount}" oninput="updateVal('holdbackAmount', this.value)">` : ''}
                        ${data.dailyPenaltyEnabled ? `<input type="text" placeholder="Daily Penalty Rate ($)" class="w-full px-4 py-2.5 rounded-lg text-sm" value="${data.dailyRate}" oninput="updateVal('dailyRate', this.value)">` : ''}
                    </div>
                `;
            }
            lucide.createIcons();
        }

        function updateVal(key, val) {
            data[key] = val;
            update();
        }

        function formatCurrency(val) {
            const num = parseFloat(val.toString().replace(/[^0-9.]/g, '')) || 0;
            return num.toLocaleString('en-US', { minimumFractionDigits: 2 });
        }

        function calculateBalance() {
            const total = parseFloat(data.purchasePrice.replace(/[^0-9.]/g, '')) || 0;
            const emd = parseFloat(data.earnestMoney.replace(/[^0-9.]/g, '')) || 0;
            return (total - emd).toLocaleString('en-US', { minimumFractionDigits: 2 });
        }

        function update() {
            const canvas = document.getElementById('doc-canvas');
            
            let headerHtml = `
                <div class="flex justify-between items-start mb-12 border-b-4 border-gray-900 pb-8">
                    <div>
                        <h2 class="text-4xl font-black mb-1 tracking-tighter uppercase leading-none text-gray-900">HYDROLEAD</h2>
                        <p class="text-[11px] uppercase font-bold text-gray-500 tracking-[0.5em] mt-2">Capital Ventures LLC</p>
                    </div>
                    <div class="text-right uppercase">
                        <h1 class="text-xl font-bold tracking-widest underline decoration-2 underline-offset-8 text-gray-900">
                            ${activeTab === 'purchase' ? 'RESIDENTIAL REAL ESTATE PURCHASE AGREEMENT' : 
                              activeTab === 'assignment' ? 'ASSIGNMENT OF PURCHASE & SALE AGREEMENT' : 
                              'POST-CLOSING OCCUPANCY ADDENDUM'}
                        </h1>
                        <p class="text-[12px] font-sans mt-4 font-bold text-gray-500">Effective Date: ${data.effectiveDate}</p>
                    </div>
                </div>
                <div class="text-[15px] leading-[1.7] space-y-6 text-gray-800">
            `;

            let bodyHtml = "";

            if (activeTab === 'purchase') {
                bodyHtml = `
                    <section><p>This <strong>RESIDENTIAL REAL ESTATE PURCHASE AGREEMENT</strong> (the "Agreement") is entered into on <strong>${data.effectiveDate}</strong>, by and between:</p>
                    <div class="pl-6 italic my-4 space-y-1">
                        <p><strong>SELLER:</strong> ${data.sellerName || '________________________'}, of ${data.sellerMailingAddress || '________________________'}.</p>
                        <p><strong>BUYER:</strong> ${data.buyerName}, of ${data.buyerMailingAddress}.</p>
                    </div></section>

                    <section><h3 class="font-bold border-b-2 border-gray-400 mb-2 uppercase text-[12px] tracking-widest text-gray-900">1. PROPERTY DESCRIPTION</h3>
                    <p>Seller agrees to sell and Buyer agrees to purchase the Property located at <strong>${data.propertyAddress}, ${data.propertyCity}, ${data.propertyState}</strong>, County of <strong>${data.propertyCounty}</strong>. <strong>LEGAL DESCRIPTION:</strong> ${data.legalDescription || "To be provided by Title Company and incorporated by reference"}. All fixtures and improvements are included unless specifically excluded in writing.</p></section>

                    <section><h3 class="font-bold border-b-2 border-gray-400 mb-2 uppercase text-[12px] tracking-widest text-gray-900">2. PURCHASE PRICE & PAYMENT TERMS</h3>
                    <p>Total Purchase Price: <strong>$${formatCurrency(data.purchasePrice)}</strong>. Buyer shall deposit <strong>$${formatCurrency(data.earnestMoney)}</strong> as Earnest Money Deposit (EMD) with the Title Company within ${data.emdDeadlineDays} days of the Effective Date. The balance of <strong>$${calculateBalance()}</strong> shall be paid at Closing via wire transfer. EMD is fully refundable during the Inspection Period.</p></section>

                    <section><h3 class="font-bold border-b-2 border-gray-400 mb-2 uppercase text-[12px] tracking-widest text-gray-900">3. CLOSING & ESCROW</h3>
                    <p>Closing shall occur <strong>on or before ${data.closingDate || '[CLOSING DATE]'}</strong> at a Title Company/Escrow Holder selected by Buyer. Possession shall be delivered to Buyer at Closing, vacant and free of all occupants and personal property unless otherwise agreed.</p></section>

                    <section><h3 class="font-bold border-b-2 border-gray-400 mb-2 uppercase text-[12px] tracking-widest text-gray-900">4. FEASIBILITY / INSPECTION PERIOD</h3>
                    <p>Buyer shall have <strong>${data.inspectionDays} days</strong> from the Effective Date (the "Inspection Period") to conduct all due diligence and inspections. Buyer may terminate this Agreement for any reason during the Inspection Period by providing written notice to Seller, in which case the EMD shall be returned to Buyer in full. <strong>TIME IS OF THE ESSENCE.</strong></p></section>

                    <section><h3 class="font-bold border-b-2 border-gray-400 mb-2 uppercase text-[12px] tracking-widest text-gray-900">5. ACCESS & ASSIGNMENT</h3>
                    <p><strong>ACCESS:</strong> Seller shall provide Buyer, its agents, contractors, partners, and prospective assignees access to the Property with 24-hour notice. <strong>ASSIGNMENT:</strong> Seller acknowledges Buyer is an investor and may <strong>assign this Agreement</strong> for a profit without further consent from Seller. Assignee shall assume all rights and obligations of Buyer.</p></section>

                    <section><h3 class="font-bold border-b-2 border-gray-400 mb-2 uppercase text-[12px] tracking-widest text-gray-900">6. EQUITABLE INTEREST DISCLOSURE</h3>
                    <p>Seller acknowledges that Buyer holds an equitable interest in the Property under this Agreement and that Buyer may market said interest to third parties, partners, or end-buyers at Buyer's sole discretion.</p></section>

                    <section><h3 class="font-bold border-b-2 border-gray-400 mb-2 uppercase text-[12px] tracking-widest text-gray-900">7. PROPERTY CONDITION (AS-IS)</h3>
                    <p>The Property is sold in <strong>"AS-IS, WHERE-IS"</strong> condition, with all faults. Seller makes no warranties or representations except as expressly stated herein. Buyer is responsible for independent due diligence and accepts the Property in its current state.</p></section>

                    <section><h3 class="font-bold border-b-2 border-gray-400 mb-2 uppercase text-[12px] tracking-widest text-gray-900">8. TITLE & CONVEYANCE</h3>
                    <p>Seller shall convey marketable title by <strong>General Warranty Deed</strong> (or state equivalent), free and clear of all liens. Owner's Title Policy shall be paid for by the <strong>${data.titlePolicyPayor}</strong>.</p></section>

                    <section><h3 class="font-bold border-b-2 border-gray-400 mb-2 uppercase text-[12px] tracking-widest text-gray-900">9. COSTS & PRORATIONS</h3>
                    <p>Real property taxes, HOA fees, and other prorations shall be prorated to the date of Closing. Utilities shall be the responsibility of Seller up to the date of Closing.</p></section>

                    <section><h3 class="font-bold border-b-2 border-gray-400 mb-2 uppercase text-[12px] tracking-widest text-gray-900">10. DEFAULT & REMEDIES</h3>
                    <p>If Buyer defaults after the Inspection Period, Seller's <strong>sole and exclusive remedy</strong> shall be the retention of the EMD as liquidated damages. If Seller defaults, Buyer may seek specific performance or a full refund of the EMD.</p></section>

                    <section><h3 class="font-bold border-b-2 border-gray-400 mb-2 uppercase text-[12px] tracking-widest text-gray-900">11. LEAD-BASED PAINT DISCLOSURE</h3>
                    <p>If the Property was built prior to 1978, Seller shall provide federally required Lead-Based Paint disclosures and an executed addendum as required by law.</p></section>

                    <section><h3 class="font-bold border-b-2 border-gray-400 mb-2 uppercase text-[12px] tracking-widest text-gray-900">12. ENTIRE AGREEMENT</h3>
                    <p>This Agreement constitutes the entire agreement between the parties and supersedes all prior discussions. This Agreement may only be amended by a written instrument signed by both parties.</p></section>

                    <section><h3 class="font-bold border-b-2 border-gray-400 mb-2 uppercase text-[12px] tracking-widest text-gray-900">13. SEVERABILITY & GOVERNING LAW</h3>
                    <p>This Agreement shall be governed by the laws of the State of <strong>${data.propertyState}</strong>. If any provision is held to be invalid, the remaining provisions shall continue in full force and effect.</p></section>
                `;
            } else if (activeTab === 'assignment') {
                bodyHtml = `
                    <section><p>This <strong>ASSIGNMENT OF PURCHASE AND SALE AGREEMENT</strong> ("Assignment") is executed this <strong>${data.effectiveDate}</strong>, by and between:</p>
                    <div class="pl-6 italic my-4 space-y-1">
                        <p><strong>ASSIGNOR:</strong> ${data.buyerName}</p>
                        <p><strong>ASSIGNEE:</strong> ${data.assigneeName || '________________________'}, of ${data.assigneeAddress || '________________________'}.</p>
                    </div></section>

                    <section><h3 class="font-bold border-b-2 border-gray-400 mb-2 uppercase text-[12px] tracking-widest text-gray-900">1. RECITALS</h3>
                    <p>Assignor is the Buyer under a certain Real Estate Purchase Agreement dated <strong>${data.originalContractDate || '[DATE]'}</strong> (the "Purchase Contract") with <strong>${data.sellerName || '[SELLER]'}</strong> as Seller, for the Property located at <strong>${data.propertyAddress}</strong>.</p></section>

                    <section><h3 class="font-bold border-b-2 border-gray-400 mb-2 uppercase text-[12px] tracking-widest text-gray-900">2. ASSIGNMENT & FEE</h3>
                    <p>Assignor hereby assigns to Assignee all right, title, and interest in the Purchase Contract. In consideration for this assignment, Assignee shall pay Assignor an Assignment Fee of <strong>$${formatCurrency(data.assignmentFee)}</strong> at the time of Closing. <strong>This Assignment Fee is earned upon execution and payable at Closing. Fee is non-refundable unless the original Purchase Contract is terminated due to Assignor default.</strong></p></section>

                    <section><h3 class="font-bold border-b-2 border-gray-400 mb-2 uppercase text-[12px] tracking-widest text-gray-900">3. ASSIGNEE EARNEST MONEY DEPOSIT</h3>
                    <p>Assignee shall deposit a non-refundable Earnest Money Deposit of <strong>$${formatCurrency(data.assignmentEMD)}</strong> with the Title Company within <strong>${data.assignmentEMDDeadline} hours</strong> of execution of this Assignment. <strong>Said deposit shall be credited toward the total amount due at Closing.</strong> Failure to deposit within the specified timeframe shall constitute a material breach of this Assignment.</p></section>

                    <section><h3 class="font-bold border-b-2 border-gray-400 mb-2 uppercase text-[12px] tracking-widest text-gray-900">4. ASSUMPTION OF PERFORMANCE</h3>
                    <p>Assignee accepts the Purchase Contract "AS-IS" and assumes all duties and obligations of the Buyer therein. Assignee acknowledges they have conducted all due diligence prior to signing. Assignee acknowledges that Assignor makes no representations as to the physical condition of the Property or the status of title. <strong>Assignor makes no warranties and shall not be responsible for closing should Assignee fail to perform.</strong></p></section>

                    <section><h3 class="font-bold border-b-2 border-gray-400 mb-2 uppercase text-[12px] tracking-widest text-gray-900">5. INDEMNIFICATION</h3>
                    <p>Assignee shall indemnify, defend, and hold Assignor harmless from any and all claims, damages, or liabilities arising under the Purchase Contract from and after the date of this Assignment.</p></section>
                `;
            } else {
                bodyHtml = `
                    <section><p>This <strong>POST-CLOSING OCCUPANCY ADDENDUM</strong> is made part of the Purchase Agreement dated <strong>${data.effectiveDate}</strong> for the property located at <strong>${data.propertyAddress}</strong>.</p></section>

                    <section><h3 class="font-bold border-b-2 border-gray-400 mb-2 uppercase text-[12px] tracking-widest text-gray-900">1. POSSESSION TERM</h3>
                    <p>Buyer agrees to permit Seller to remain in possession of the Property after Closing until <strong>${data.moveOutDate || '[DATE]'}</strong>. Seller shall vacate the Property no later than <strong>${data.moveOutTime}</strong> local time. This creates a temporary license to occupy and specifically <strong>NO landlord-tenant relationship</strong> is created.</p></section>

                    <section><h3 class="font-bold border-b-2 border-gray-400 mb-2 uppercase text-[12px] tracking-widest text-gray-900">2. BROOM-CLEAN CONDITION</h3>
                    <p>Seller must deliver the Property in <strong>broom-clean condition</strong> and free of all debris and personal property. All keys and access devices must be delivered to Buyer at the moment of vacancy.</p></section>

                    ${data.holdbackEnabled ? `
                    <section><h3 class="font-bold border-b-2 border-gray-400 mb-2 uppercase text-[12px] tracking-widest text-gray-900">3. ESCROW HOLDBACK</h3>
                    <p>At Closing, the sum of <strong>$${formatCurrency(data.holdbackAmount)}</strong> shall be held in escrow by the Title Company. Funds shall be released only after Buyer verifies vacancy and condition. Buyer may deduct repair costs, unpaid utilities, or holdover penalties from this Holdback.</p></section>` : ''}

                    ${data.dailyPenaltyEnabled ? `
                    <section><h3 class="font-bold border-b-2 border-gray-400 mb-2 uppercase text-[12px] tracking-widest text-gray-900">4. DAILY HOLDOVER PENALTY</h3>
                    <p>If Seller fails to vacate by the Expiration Date, Seller shall pay Buyer a penalty of <strong>$${formatCurrency(data.dailyRate)} per day</strong>. Payment of this penalty does not extend the term of occupancy.</p></section>` : ''}

                    <section><h3 class="font-bold border-b-2 border-gray-400 mb-2 uppercase text-[12px] tracking-widest text-gray-900">5. UTILITIES & MAINTENANCE</h3>
                    <p>Seller shall remain responsible for all utilities, lawn care, and maintenance during the occupancy period. Utilities must remain active and in Seller's name until vacancy.</p></section>

                    <section><h3 class="font-bold border-b-2 border-gray-400 mb-2 uppercase text-[12px] tracking-widest text-gray-900">6. RISK OF LOSS & INDEMNIFICATION</h3>
                    <p>Seller assumes all risk of loss for personal property and for any injury occurring on the Property. <strong>Seller shall indemnify and hold Buyer harmless</strong> from all claims arising from Seller's occupancy. <strong>TIME IS OF THE ESSENCE.</strong></p></section>
                `;
            }

            // Footer / Signature Section
            let footerHtml = "";
            if (activeTab === 'assignment') {
                footerHtml = `
                <div class="mt-24 grid grid-cols-2 gap-20 pt-12 border-t-2 border-gray-100">
                    <div class="space-y-6">
                        <p class="text-[11px] font-black uppercase text-gray-400 tracking-widest border-b-2 pb-1">Assignor Acceptance</p>
                        <div class="h-12 border-b-2 border-black flex items-end px-2 font-sans italic text-blue-700 font-bold text-lg">
                            /s/ HydroLead Capital Ventures LLC
                        </div>
                        <p class="text-[13px] font-sans font-bold">Name: HydroLead Capital Ventures LLC</p>
                        <p class="text-[13px] font-sans">Date: ${new Date().toLocaleDateString()}</p>
                    </div>
                    <div class="space-y-6">
                        <p class="text-[11px] font-black uppercase text-gray-400 tracking-widest border-b-2 pb-1">Assignee Acceptance</p>
                        <div class="h-12 border-b-2 border-black flex items-end px-2 font-sans italic text-blue-700 font-bold text-lg">
                            /s/ ${data.assigneeName || '_________________________'}
                        </div>
                        <p class="text-[13px] font-sans font-bold">Name: ${data.assigneeName || '_________________________'}</p>
                        <p class="text-[13px] font-sans">Date: _________________________</p>
                    </div>
                </div>`;
            } else {
                footerHtml = `
                <div class="mt-24 grid grid-cols-2 gap-20 pt-12 border-t-2 border-gray-100">
                    <div class="space-y-6">
                        <p class="text-[11px] font-black uppercase text-gray-400 tracking-widest border-b-2 pb-1">Seller Acceptance</p>
                        <div class="h-12 border-b-2 border-black"></div>
                        <p class="text-[13px] font-sans font-bold">Name: ${data.sellerName || '_________________________'}</p>
                        <p class="text-[13px] font-sans">Date: _________________________</p>
                    </div>
                    <div class="space-y-6">
                        <p class="text-[11px] font-black uppercase text-gray-400 tracking-widest border-b-2 pb-1">Buyer Acceptance</p>
                        <div class="h-12 border-b-2 border-black flex items-end px-2 font-sans italic text-blue-700 font-bold text-lg">
                            /s/ HydroLead Capital Ventures LLC
                        </div>
                        <p class="text-[13px] font-sans font-bold">Name: HydroLead Capital Ventures LLC</p>
                        <p class="text-[13px] font-sans">Date: ${new Date().toLocaleDateString()}</p>
                    </div>
                </div>`;
            }

            footerHtml += `
                <div class="pt-12 mt-16 border-t border-gray-100 text-[10px] text-gray-400 uppercase flex justify-between font-bold tracking-tighter">
                    <span>HYDROLEAD CAPITAL VENTURES LLC - OFFICIAL DOCUMENTATION</span>
                    <span>SECTION: ${activeTab.toUpperCase()} | PAGE 1 OF 1</span>
                </div>
            </div>`;

            canvas.innerHTML = headerHtml + bodyHtml + footerHtml;
        }

        window.onload = () => {
            document.getElementById('effectiveDate').value = data.effectiveDate;
            renderSidebar();
            setActiveTab('purchase');
        };
    </script>
</body>
